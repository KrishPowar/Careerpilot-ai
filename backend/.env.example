FLASK_ENV=development

# Used by Flask sessions; set to a long random value in production
SECRET_KEY=change-me-in-production

# JWT signing key used by the API
JWT_SECRET_KEY=change-me-too

# OpenRouter (chatbot)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=CareerPilot AI

# Storage paths
DATABASE_PATH=careerpilot.db
UPLOAD_FOLDER=uploads

# CORS (production): prefer setting FRONTEND_URL to the exact deployed Vercel URL
# Example: https://your-vercel-app.vercel.app
FRONTEND_URL=

# Optional: allow multiple origins (comma-separated)
# You can include regex entries by prefixing with 're:'
# Example (allow Vercel preview + prod for this project):
# FRONTEND_ORIGINS=re:^https://careerpilot-.*\\.vercel\\.app$,https://your-prod-domain.vercel.app
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173
