# Base URL of the backend (NO /api suffix).
# Local dev: http://localhost:5000
# Production (Render): https://your-render-backend-url.onrender.com
VITE_API_BASE_URL=http://localhost:5000

# Optional: set true to force the browser to call the backend directly (requires CORS configured on Render).
# Default is false (recommended): in production the frontend calls same-origin /api/* and uses the Vercel proxy.
VITE_FORCE_DIRECT_API=false

# Optional (recommended on Vercel): set this in Vercel Project → Settings → Environment Variables.
# Used by the serverless proxy in 'frontend/api/' so the frontend can call same-origin /api/*.
CAREERPILOT_BACKEND_URL=https://your-render-backend-url.onrender.com
